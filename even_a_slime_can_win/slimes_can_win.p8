--utility functions

function wait_check()	
	if wait==0 then
		return true
	else
		wait-=1
		return false
	end
end

function set_wait(num)
	wait=num
end

function nearest_npc(px,py,range)
 local best=nil
 local best_dst=range*range

 for _,npc in pairs(npcs) do
  local dx=npc.x-px
  local dy=npc.y-py
  local dst=dx*dx+dy*dy
  if dst<=best_dst then
   best=npc
   best_dst=dst
  end
 end

 return best
end

function menu_control(option_cnt)
	if btnp(2) then 
		menu_sel-=1
		if menu_sel<1 then
			menu_sel=option_cnt
		end 
	end
	if btnp(3) then 
		menu_sel+=1 
		if menu_sel>option_cnt then
			menu_sel=1
		end
	end
	if btnp(4) then
		return true
	end
end
